# Copy to contracts/.env and fill in. Never commit .env.

# Deployer key, funded with Sepolia ETH. Generate/hold securely; use a throwaway for testnet.
PRIVATE_KEY=0x...

# Sepolia RPC (public option: https://rpc.sepolia.org — or Alchemy/Infura for reliability).
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# USDC on Sepolia (Circle's official test USDC). Override for a different token.
USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# Role addresses. Keep COORDINATOR separate from ADMIN.
ADMIN_ADDRESS=0x...
COORDINATOR_ADDRESS=0x...
TREASURY_ADDRESS=0x...

# For contract verification on Etherscan (optional).
ETHERSCAN_API_KEY=
