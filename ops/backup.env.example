# Copy to /etc/gridix-backup.env (root-only: chmod 600) and adjust. The values below match
# the S3/MinIO stack in smoke/docker-compose.s3.yml. For real AWS S3: drop
# GRIDIX_S3_ENDPOINT_URL and GRIDIX_BACKUP_DOCKER_NETWORK, and use real AWS creds.

# AES passphrase file for encrypt-at-rest. Create once, root-only:
#   openssl rand -base64 48 > /etc/gridix-backup.key && chmod 600 /etc/gridix-backup.key
GRIDIX_BACKUP_KEY_FILE=/etc/gridix-backup.key

GRIDIX_S3_BUCKET=gridix-backups
GRIDIX_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=gridixadmin
AWS_SECRET_ACCESS_KEY=gridixsecret123
AWS_DEFAULT_REGION=us-east-1
GRIDIX_BACKUP_RETENTION_DAYS=7

# Dump via docker exec into the running Postgres container (version-safe). Omit both to use a
# host pg_dump against PGHOST/PGPORT instead (managed Postgres).
GRIDIX_BACKUP_PG_CONTAINER=gridixs3-postgres-1
PGPASSWORD=gridix
PGUSER=gridix
PGDATABASE=gridix

# Docker network so the mc uploader can reach an in-network MinIO by service name.
GRIDIX_BACKUP_DOCKER_NETWORK=gridixs3_default

# Restore drill target (a scratch DB in the same Postgres).
GRIDIX_RESTORE_PG_CONTAINER=gridixs3-postgres-1
GRIDIX_RESTORE_DB=gridix_restore
