# GRIDIX frontend environment.
# Copy to .env.local and fill in. All are validated at boot (fail-fast).

# Control-plane API base URL (FastAPI). No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:8000

# EVM chain the app talks to. 11155111 = Sepolia testnet.
NEXT_PUBLIC_CHAIN_ID=11155111

# JSON-RPC endpoint for on-chain reads (wagmi/viem).
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Contract addresses the app transacts against.
# Production Sepolia deployment uses Circle USDC (0x1c7D…7238), which is
# unmintable — so for a working testnet deposit demo, point these at the mock
# exercise pair (mintable MockUSDC). On mainnet, use the production pair + real USDC.
#   Production:  escrow 0xd93076eb67ab21ae068c0ad7a6256ca6ba58f733, usdc 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
#   Testnet demo: escrow 0x04B237e8b5F3de59F02C3E61007351Eb5d8CA09B, usdc 0x48d9eb22261094f9C2F31587daD06fa80df6d23B
NEXT_PUBLIC_ESCROW_ADDRESS=0x04B237e8b5F3de59F02C3E61007351Eb5d8CA09B
NEXT_PUBLIC_USDC_ADDRESS=0x48d9eb22261094f9C2F31587daD06fa80df6d23B
NEXT_PUBLIC_STAKING_ADDRESS=0x72089171441d05ad2a64777177fF2864a9703822
