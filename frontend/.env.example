# GRIDIX frontend environment.
# Copy to .env.local and fill in. All are validated at boot (fail-fast).

# Control-plane API base URL (FastAPI). No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:8000

# EVM chain the app talks to. 11155111 = Sepolia testnet.
NEXT_PUBLIC_CHAIN_ID=11155111

# Deployed contract addresses (Sepolia production instances).
NEXT_PUBLIC_ESCROW_ADDRESS=0xd93076eb67ab21ae068c0ad7a6256ca6ba58f733
NEXT_PUBLIC_STAKING_ADDRESS=0x72089171441d05ad2a64777177fF2864a9703822

# Circle Sepolia USDC (6 decimals).
NEXT_PUBLIC_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
