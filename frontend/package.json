{
  "name": "gridix-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:types": "openapi-typescript ./openapi.snapshot.json -o ./src/lib/api/schema.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.2",
    "next": "15.5.20",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "server-only": "0.0.1",
    "viem": "2.55.2",
    "wagmi": "3.7.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6",
    "@testing-library/react": "16",
    "@testing-library/user-event": "14",
    "@types/node": "22.10.10",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitejs/plugin-react": "4",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.20",
    "jsdom": "25",
    "openapi-typescript": "7.13.0",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.11",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "3.0.5"
  }
}
