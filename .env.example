# GRIDIX backend configuration — copy to .env and fill in. Never commit .env.

# Deployment environment: dev | staging | prod
GRIDIX_ENV=dev

# CORS: comma-separated EXACT browser origins allowed to call the API cross-origin.
# Empty = none (the frontend uses a same-origin proxy). NEVER set this to "*".
GRIDIX_CORS_ALLOW_ORIGINS=

# Postgres (async DSN — SQLAlchemy uses the asyncpg driver). In production the
# password must come from a secret store (env/Docker secret/Vault), never a
# committed literal; the compose files read ${POSTGRES_PASSWORD}. Rotate any
# leaked value — don't reuse it.
POSTGRES_PASSWORD=CHANGE_ME_generate_a_real_db_password
GRIDIX_DATABASE_URL=postgresql+asyncpg://gridix:CHANGE_ME_generate_a_real_db_password@postgres:5432/gridix

# Redis (job queue + rate limiting)
GRIDIX_REDIS_URL=redis://redis:6379/0

# Object storage (S3/MinIO) for job input/result blobs when GRIDIX_STORAGE_BACKEND=s3.
# Use least-privilege, non-admin credentials scoped to the blob bucket; the compose
# files read ${MINIO_ROOT_USER}/${MINIO_ROOT_PASSWORD}. Placeholders only:
MINIO_ROOT_USER=CHANGE_ME_storage_access_key
MINIO_ROOT_PASSWORD=CHANGE_ME_storage_secret_key

# Secrets (Session 12.1). Backend: env (below) | file (/run/secrets/GRIDIX_*) | vault (seam).
# Outside GRIDIX_ENV=dev the app refuses to start unless the FOUR separated secrets
# below, plus KEK and ATTESTATION_SECRET, are set to real, DISTINCT, non-default
# values (fail-fast at startup). ROTATION: if any secret has ever been exposed,
# generate a NEW value — never reuse a leaked one. Each secret rotates independently.
GRIDIX_SECRET_BACKEND=env
GRIDIX_SECRET_DIR=/run/secrets
# Vault backend (GRIDIX_SECRET_BACKEND=vault) — for the coordinator key especially. See docs/VAULT.md.
# Install with `.[vault]`. role_id/secret_id are the bootstrap secret-zero (inject at launch).
# GRIDIX_VAULT_ADDR=https://vault.internal:8200
# GRIDIX_VAULT_AUTH_METHOD=approle
# GRIDIX_VAULT_ROLE_ID=
# GRIDIX_VAULT_SECRET_ID=
# GRIDIX_VAULT_KV_MOUNT=secret
# GRIDIX_VAULT_SECRET_PATH=gridix

# Legacy single secret — dev fallback ONLY. In production it is ignored; set the
# four separated secrets below instead. Generate any secret with: openssl rand -hex 32
GRIDIX_SECRET_KEY=change-me-please-generate-a-real-32-byte-hex-secret

# Secret separation (security wave 1): one leaked secret must not forge everything.
# Each function has its OWN secret with zero cross-use. All four are required in
# production, must be distinct, and must not equal the dev default. Generate each
# with: openssl rand -hex 32
GRIDIX_HMAC_KEY=          # signs/looks up developer & provider API keys
GRIDIX_OPERATOR_SECRET=   # authenticates operator-only endpoints
GRIDIX_RELAY_SECRET=      # authenticates the coordinator↔relay bridge
GRIDIX_ENDPOINT_KEY=      # signs endpoint + job capability tokens

# Coordinator key-encryption key for per-job data-key brokering (Fernet key).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GRIDIX_KEK=
# Retired KEKs (comma-separated) still accepted during zero-downtime rotation.
GRIDIX_KEK_PREVIOUS=

# TEE attestation root-of-trust secret. Generate with: openssl rand -hex 32
GRIDIX_ATTESTATION_SECRET=

# Blob storage backend for job input/result: local | s3
GRIDIX_STORAGE_BACKEND=local
GRIDIX_STORAGE_LOCAL_PATH=/data/blobs

# Scheduler / reliability tuning
GRIDIX_LEASE_SECONDS=60
GRIDIX_MAX_ATTEMPTS=3

# Verification / economics
GRIDIX_CANARY_RATE=0.05
GRIDIX_MIN_PROVIDER_STAKE=100
GRIDIX_PROTOCOL_FEE_BPS=250
