# GRIDIX on-chain settlement (Session 13) — copy the vars you need into .env and fill in.
# Never commit a real .env or any private key.
#
# The off-chain double-entry ledger stays the source of truth for per-job accounting; this
# layer only mirrors deposits in and pushes *aggregate* settlements out. With chain disabled
# (the default) nothing here is read and the backend runs fiat-only (FiatStub), fully hermetic.
#
# Contract addresses/roles below are the LIVE Sepolia deployment recorded in
# contracts/EVIDENCE.md (chain id 11155111). See docs/SETTLEMENT.md for the money model.

# Master switch. false = fiat-only, no RPC (default). Set true to talk to the chain.
GRIDIX_CHAIN_ENABLED=true

# JSON-RPC endpoint. Must serve log history for catch-up scans. This public node works;
# swap for Alchemy/Infura for reliability. (rpc.sepolia.org 404s — do not use it here.)
GRIDIX_CHAIN_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
GRIDIX_CHAIN_ID=11155111

# Deployed contracts (Sepolia) — from contracts/EVIDENCE.md.
GRIDIX_ESCROW_ADDRESS=0xd93076eb67ab21ae068c0ad7a6256ca6ba58f733
GRIDIX_STAKING_ADDRESS=0x72089171441d05ad2a64777177fF2864a9703822
# Circle's official Sepolia test USDC (symbol=USDC, decimals=6).
GRIDIX_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
GRIDIX_USDC_DECIMALS=6

# Coordinator EOA private key — MUST hold COORDINATOR_ROLE on BOTH contracts. On the live
# deployment the role was rotated to a key we control: 0xBbBe5A990C8e0C9B174309d5e0E1f1C932F774E9
# (see contracts/EVIDENCE.md). Signs debit / settleBatch / depositSettlement. NEVER hardcode a real
# key here — source it from Vault (GRIDIX_SECRET_BACKEND=vault; see docs/VAULT.md). Leave empty so
# bootstrap fetches it from the secret manager on demand (it never lands in Settings).
GRIDIX_COORDINATOR_PRIVATE_KEY=
# Startup guard: the address the coordinator key MUST derive to (the on-chain role holder). If set,
# the backend fails fast on mismatch so a wrong/rotated key can't sign against real escrow silently.
GRIDIX_EXPECTED_COORDINATOR_ADDRESS=0xBbBe5A990C8e0C9B174309d5e0E1f1C932F774E9

# Start the watcher's cursor at the escrow deploy block so catch-up never scans genesis→now.
# Escrow deployed at block 11262619; staking at 11262679 — use the earlier of the two.
GRIDIX_CHAIN_START_BLOCK=11262619

# Reorg guard: confirmations before an event/receipt is treated as final.
GRIDIX_CHAIN_CONFIRMATIONS=3
# Max blocks per eth_getLogs (public RPCs cap wide ranges); the watcher scans in these windows.
GRIDIX_CHAIN_LOG_WINDOW=500

# Settlement trigger: batch when unsettled provider earnings reach the threshold (whole USDC)
# OR when the interval elapses — whichever comes first (see docs/SETTLEMENT.md).
GRIDIX_SETTLEMENT_THRESHOLD_USDC=100
GRIDIX_SETTLEMENT_INTERVAL_SECONDS=3600
# On-chain vs off-chain reconciliation cadence (sets gridix_chain_ledger_divergence).
GRIDIX_RECONCILE_INTERVAL_SECONDS=300

# Install the driver with the optional extra: pip install '.[chain]'  (web3, lazy-imported).
